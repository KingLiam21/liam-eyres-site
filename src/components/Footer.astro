---
// Footer — about, contact, CV download
---

<footer class="footer" id="about">
  <div class="container">
    <div class="footer-grid">
      <!-- About -->
      <div class="footer-about reveal">
        <div class="footer-headshot">
          <img
            src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=400&q=80"
            alt="Liam Eyres"
            loading="lazy"
          />
        </div>
        <h3 class="footer-name">Liam Eyres</h3>
        <p class="footer-bio">
          Sales leader who builds high-performing teams from scratch. 12+ years across SaaS, proptech, 
          automotive, and telecoms. When I'm not closing deals or coaching teams, I'm flying drones, 
          shooting photos, or building websites like this one.
        </p>
        <p class="footer-location">📍 Liverpool, UK</p>
      </div>

      <!-- Quick Links -->
      <div class="footer-links reveal" style="transition-delay: 0.1s">
        <h4 class="footer-heading">Explore</h4>
        <nav class="footer-nav">
          <a href="#sales">Sales Experience</a>
          <a href="#websites">Websites</a>
          <a href="#aerial">Aerial Filmmaking</a>
          <a href="#photography">Photography</a>
          <a href="/blog">Blog</a>
        </nav>
      </div>

      <!-- Contact -->
      <div class="footer-contact reveal" style="transition-delay: 0.2s">
        <h4 class="footer-heading">Get in Touch</h4>
        <div class="footer-contact-items">
          <a href="tel:+447507554995" class="footer-contact-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"></path>
            </svg>
            +44 7507 554995
          </a>
          <a href="mailto:eyresliam@outlook.com" class="footer-contact-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
            eyresliam@outlook.com
          </a>
          <a href="https://linkedin.com/in/liameyres" target="_blank" rel="noopener" class="footer-contact-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"></path>
              <rect x="2" y="9" width="4" height="12"></rect>
              <circle cx="4" cy="4" r="2"></circle>
            </svg>
            LinkedIn
          </a>
        </div>

        <div class="footer-actions">
          <button class="btn-primary" data-contact>Contact Me</button>
          <a href="/Liam-Eyres-CV.pdf" class="btn-secondary" target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            Download CV
          </a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} Liam Eyres. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 100px 0 40px;
    border-top: 1px solid var(--color-gray-500);
    background: var(--color-bg);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1.2fr;
    gap: 60px;
    margin-bottom: 60px;
  }

  /* About */
  .footer-headshot {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--color-purple);
    margin-bottom: 20px;
  }

  .footer-headshot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .footer-name {
    color: var(--color-gold);
    font-size: 1.5rem;
    margin-bottom: 12px;
  }

  .footer-bio {
    font-size: 0.95rem;
    color: var(--color-gray-200);
    line-height: 1.7;
    margin-bottom: 12px;
  }

  .footer-location {
    font-size: 0.9rem;
    color: var(--color-gray-300);
  }

  /* Links */
  .footer-heading {
    color: var(--color-white);
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 20px;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-nav a {
    font-size: 0.9rem;
    color: var(--color-gray-200);
    transition: all var(--transition-fast);
  }

  .footer-nav a:hover {
    color: var(--color-gold);
    transform: translateX(4px);
    display: inline-block;
  }

  /* Contact */
  .footer-contact-items {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 28px;
  }

  .footer-contact-link {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.9rem;
    color: var(--color-gray-200);
    transition: color var(--transition-fast);
  }

  .footer-contact-link:hover {
    color: var(--color-gold);
  }

  .footer-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-actions .btn-primary,
  .footer-actions .btn-secondary {
    text-align: center;
    justify-content: center;
    font-size: 0.85rem;
    padding: 12px 24px;
  }

  /* Bottom */
  .footer-bottom {
    border-top: 1px solid var(--color-gray-500);
    padding-top: 24px;
    text-align: center;
  }

  .footer-bottom p {
    font-size: 0.8rem;
    color: var(--color-gray-400);
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .footer {
      padding: 60px 0 30px;
    }
  }
</style>
