---
// Latest Blog Posts — shows 3 most recent on homepage
import { getCollection, render } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

// Calculate reading time for each post
const posts = await Promise.all(
  allPosts.map(async (post) => {
    const { remarkPluginFrontmatter } = await render(post);
    const body = post.body || '';
    const wordCount = body.split(/\s+/).filter(Boolean).length;
    const readingTime = Math.max(1, Math.ceil(wordCount / 230));
    return { ...post, readingTime };
  })
);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  });
}
---

<section class="latest-posts" id="blog-preview">
  <div class="container">
    <div class="posts-header reveal">
      <span class="section-label">Thoughts & Insights</span>
      <h2 class="section-title">Latest Posts</h2>
    </div>

    <div class="posts-grid">
      {posts.map((post, i) => (
        <a href={`/blog/${post.id}`} class={`post-card reveal`} style={`transition-delay: ${i * 0.15}s`}>
          <div class="post-meta">
            <span class="post-date">{formatDate(post.data.date)}</span>
            <span class="post-reading-time">{post.readingTime} min read</span>
            {post.data.tags && post.data.tags[0] && (
              <span class="post-tag">{post.data.tags[0]}</span>
            )}
          </div>
          <h4 class="post-title">{post.data.title}</h4>
          <p class="post-excerpt">{post.data.description}</p>
          <span class="post-read-more">Read More →</span>
        </a>
      ))}
    </div>

    <div class="posts-cta reveal">
      <a href="/blog" class="btn-secondary">View All Posts →</a>
    </div>
  </div>
</section>

<style>
  .latest-posts {
    padding: var(--section-padding);
  }

  .posts-header {
    text-align: center;
    margin-bottom: 50px;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    margin-bottom: 50px;
  }

  .post-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-gray-500);
    border-radius: var(--border-radius);
    padding: 32px;
    transition: all var(--transition-fast);
    display: flex;
    flex-direction: column;
  }

  .post-card:hover {
    border-color: var(--color-purple);
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(123, 47, 190, 0.15);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .post-date {
    font-size: 0.8rem;
    color: var(--color-gray-300);
    font-weight: 500;
  }

  .post-reading-time {
    font-size: 0.75rem;
    color: var(--color-gray-300);
    font-weight: 500;
    opacity: 0.8;
  }

  .post-tag {
    padding: 3px 10px;
    background: rgba(123, 47, 190, 0.15);
    border-radius: 20px;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-purple-light);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .post-title {
    color: var(--color-white);
    font-size: 1.2rem;
    margin-bottom: 12px;
    line-height: 1.3;
    transition: color var(--transition-fast);
  }

  .post-card:hover .post-title {
    color: var(--color-gold);
  }

  .post-excerpt {
    font-size: 0.9rem;
    color: var(--color-gray-200);
    line-height: 1.6;
    flex: 1;
    margin-bottom: 16px;
  }

  .post-read-more {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-purple-light);
    transition: color var(--transition-fast);
  }

  .post-card:hover .post-read-more {
    color: var(--color-gold);
  }

  .posts-cta {
    text-align: center;
  }

  @media (max-width: 768px) {
    .posts-grid {
      grid-template-columns: 1fr;
      max-width: 500px;
      margin: 0 auto 50px;
    }
  }
</style>
