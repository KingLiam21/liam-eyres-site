---
// Web Dev Portfolio — 6 browser-frame mockup cards
const projects = [
  {
    title: 'Acobas Estate Agents',
    description: 'Full website for Knutsford independent estate agents — property search, valuations, lettings, and investment services across Cheshire.',
    image: '/images/website-acobas.jpg',
    url: 'https://acobas-website.vercel.app',
    tech: ['Next.js', 'Tailwind', 'Vercel'],
  },
  {
    title: 'Voltix',
    description: 'SaaS productivity platform with AI task prioritisation, smart scheduling, and 50+ integrations. Replaces scattered tools with one workspace.',
    image: '/images/website-voltix.jpg',
    url: 'https://voltix-demo.vercel.app',
    tech: ['React', 'TypeScript', 'Vercel'],
  },
  {
    title: 'Harbor & Stone',
    description: 'Boutique hotel website with room comparisons, curated escape packages, and a cinematic coastal brand experience.',
    image: '/images/website-harborstone.jpg',
    url: 'https://harbor-stone-demo.vercel.app',
    tech: ['Astro', 'CSS', 'Vercel'],
  },
  {
    title: 'Northway Studio',
    description: 'Creative design studio site with case studies, service breakdowns, and founder testimonials. Clean, bold, conversion-focused.',
    image: '/images/website-northway.jpg',
    url: 'https://northway-studio-demo.vercel.app',
    tech: ['Next.js', 'Tailwind', 'Vercel'],
  },
  {
    title: 'SportsPulse',
    description: 'Real-time sports news platform covering 33+ sports with live scores, breaking news, and in-depth analysis.',
    image: '/images/website-sportspulse.jpg',
    url: 'https://sportspulse-ten.vercel.app',
    tech: ['React', 'TypeScript', 'Vercel'],
  },
  {
    title: 'Dickinson Body & Balance',
    description: 'Massage & wellness business site with online booking, treatment breakdowns, and a calming brand experience. Based in Brighton.',
    image: '/images/website-dickinson.jpg',
    url: 'https://dickinson-body-balance.vercel.app',
    tech: ['Astro', 'CSS', 'Vercel'],
  },
];
---

<section class="websites" id="websites">
  <div class="container">
    <div class="websites-header reveal">
      <span class="section-label">Built By Hand</span>
      <h2 class="section-title">Websites I've Built</h2>
      <p class="section-subtitle">Clean, fast, conversion-focused — the same quality you're looking at right now.</p>
    </div>

    <div class="projects-grid">
      {projects.map((project, i) => (
        <div class={`project-card reveal`} style={`transition-delay: ${i * 0.15}s`}>
          <div class="browser-frame">
            <div class="browser-bar">
              <div class="browser-dots">
                <span class="dot red"></span>
                <span class="dot yellow"></span>
                <span class="dot green"></span>
              </div>
              <div class="browser-url">
                <span>{new URL(project.url).hostname}</span>
              </div>
            </div>
            <div class="browser-content">
              <img src={project.image} alt={project.title} loading="lazy" />
              <div class="project-overlay">
                <a href={project.url} target="_blank" rel="noopener" class="view-site-btn">
                  View Live Site →
                </a>
              </div>
            </div>
          </div>
          <div class="project-info">
            <h4 class="project-title">{project.title}</h4>
            <p class="project-desc">{project.description}</p>
            <div class="project-tech">
              {project.tech.map((t) => (
                <span class="tech-tag">{t}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="websites-cta reveal">
      <p class="cta-text">Want something like this for your business?</p>
      <button class="btn-primary" data-contact>Contact Me</button>
    </div>
  </div>
</section>

<style>
  .websites {
    padding: var(--section-padding);
    background: var(--color-bg-light);
  }

  .websites-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .websites-header .section-subtitle {
    margin: 0 auto;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-bottom: 60px;
  }

  .project-card {
    transition: transform var(--transition-med);
  }

  .project-card:hover {
    transform: translateY(-8px);
  }

  /* Browser Frame */
  .browser-frame {
    border-radius: var(--border-radius);
    overflow: hidden;
    border: 1px solid var(--color-gray-500);
    background: var(--color-bg-card);
    transition: border-color var(--transition-fast);
  }

  .project-card:hover .browser-frame {
    border-color: var(--color-purple);
  }

  .browser-bar {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-gray-500);
  }

  .browser-dots {
    display: flex;
    gap: 6px;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .dot.red { background: #FF5F56; }
  .dot.yellow { background: #FFBD2E; }
  .dot.green { background: #27C93F; }

  .browser-url {
    flex: 1;
    background: var(--color-gray-500);
    border-radius: 4px;
    padding: 4px 12px;
    font-size: 0.75rem;
    color: var(--color-gray-300);
  }

  .browser-content {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .browser-content img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .project-card:hover .browser-content img {
    transform: scale(1.05);
  }

  .project-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(10, 10, 10, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity var(--transition-fast);
  }

  .project-card:hover .project-overlay {
    opacity: 1;
  }

  .view-site-btn {
    padding: 14px 28px;
    background: var(--color-gold);
    color: var(--color-bg);
    font-weight: 600;
    font-size: 0.95rem;
    border-radius: 50px;
    transition: all var(--transition-fast);
  }

  .view-site-btn:hover {
    background: var(--color-gold-light);
    transform: scale(1.05);
  }

  /* Project Info */
  .project-info {
    padding: 20px 4px;
  }

  .project-title {
    color: var(--color-white);
    font-size: 1.15rem;
    margin-bottom: 8px;
  }

  .project-desc {
    font-size: 0.9rem;
    color: var(--color-gray-200);
    margin-bottom: 12px;
    line-height: 1.5;
  }

  .project-tech {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .tech-tag {
    padding: 4px 12px;
    background: rgba(212, 175, 55, 0.1);
    border: 1px solid rgba(212, 175, 55, 0.25);
    border-radius: 20px;
    font-size: 0.75rem;
    color: var(--color-gold);
    font-weight: 500;
  }

  /* CTA */
  .websites-cta {
    text-align: center;
  }

  .cta-text {
    font-size: 1.3rem;
    color: var(--color-white);
    font-weight: 600;
    margin-bottom: 20px;
  }

  @media (max-width: 1024px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
  }

  @media (max-width: 640px) {
    .projects-grid {
      grid-template-columns: 1fr;
      max-width: 500px;
      margin: 0 auto 60px;
    }
  }
</style>
