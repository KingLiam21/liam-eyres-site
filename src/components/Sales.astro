---
// Sales Section — the dominant section, metrics + timeline + strengths
const stats = [
  { value: '£1.16M', label: 'Revenue Delivered at Rightmove', numericValue: 1.16, prefix: '£', suffix: 'M', decimals: 2 },
  { value: '12+', label: 'Years in Sales', numericValue: 12, prefix: '', suffix: '+', decimals: 0 },
  { value: '#1', label: 'Salesperson 3 Years Running', numericValue: 1, prefix: '#', suffix: '', decimals: 0 },
  { value: '40%', label: 'YoY Growth at Honda', numericValue: 40, prefix: '', suffix: '%', decimals: 0 },
];

const timeline = [
  {
    company: 'Home.co.uk / Homemove.com',
    role: 'Sales Manager / Sales Director',
    period: 'Dec 2025 – Present',
    highlights: [
      'Built the sales function from the ground up — team, process, culture.',
      'Collaborated with founders to define the product proposition (Founder 250), a B2B lead generation package.',
      'Designed the full sales process: outreach strategy, qualification framework, objection handling, and closing methodology.',
      'Created sales playbooks, scripts, and enablement materials for scalability beyond personal involvement.',
    ],
  },
  {
    company: 'Rightmove',
    role: 'Remote B2B Account Manager',
    period: 'Jan 2023 – Feb 2025',
    highlights: [
      'Delivered £1.164 million in revenue against an annual target of £144,000.',
      'Awarded "Best Overall Sales Professional" for consistently dominating the national sales team.',
      'Pioneered AI integration into mailbox workflows, reducing meeting no-shows by 20%.',
    ],
  },
  {
    company: 'Audi UK (Liverpool)',
    role: 'Senior Sales Executive',
    period: 'Sep 2019 – Jan 2023',
    highlights: [
      'Ranked top 3 in the national Audi UK performance league for 9 consecutive months.',
      'Delivered an average £890 profit-per-unit against a £350 target.',
      'Selected for the Audi UK leadership development programme.',
    ],
  },
  {
    company: "Johnson's Toyota",
    role: 'Business Manager',
    period: 'Apr 2018 – Sep 2019',
    highlights: [
      'Increased team profit-per-unit by 32% and boosted PCP product adoption by 15%.',
    ],
  },
  {
    company: 'Volkswagen (Warrington)',
    role: 'Sales Executive',
    period: 'Apr 2016 – Mar 2018',
    highlights: [
      'Exceeded monthly sales targets by 20%+. Awarded Sales Performance of the Year.',
    ],
  },
  {
    company: 'Northwest Honda',
    role: 'Sales Manager',
    period: 'Jan 2015 – Mar 2016',
    highlights: [
      'Drove 40% year-on-year sales growth and a 21% improvement in team PPU.',
    ],
  },
  {
    company: 'Millennium Motorcycles (KJM Group)',
    role: 'Sales Executive',
    period: 'Nov 2012 – Jan 2015',
    highlights: [
      'Number one salesperson for all 3 years and top performer across the wider KJM Group, outselling the next best by 20%.',
    ],
  },
];

const strengths = [
  'Sales Team Building',
  'Process Design',
  'AI-Driven Sales Automation',
  'SPIN / Challenger / Nudge',
  'CRM & Pipeline Management',
  'Coaching & Enablement',
  'Channel Strategy',
  'Strategic Negotiation',
  'Product-Market Fit',
  'Go-To-Market Strategy',
];
---

<section class="sales" id="sales">
  <div class="container">
    <!-- Stats -->
    <div class="sales-header reveal">
      <span class="section-label">What I Do Best</span>
      <h2 class="section-title">Sales Leadership</h2>
      <p class="section-subtitle">Over 12 years of building high-performing sales teams, smashing targets, and installing systems that scale.</p>
    </div>

    <div class="stats-grid reveal">
      {stats.map((stat) => (
        <div class="stat-card-wrapper">
          <div
            class="stat-card"
            data-numeric={stat.numericValue}
            data-prefix={stat.prefix}
            data-suffix={stat.suffix}
            data-decimals={stat.decimals}
          >
            <div class="stat-card-inner">
              <div class="stat-glow"></div>
              <span class="stat-value">0</span>
              <span class="stat-label">{stat.label}</span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Strengths -->
    <div class="strengths reveal">
      {strengths.map((s) => (
        <span class="strength-pill">{s}</span>
      ))}
    </div>

    <!-- Timeline -->
    <div class="timeline">
      {timeline.map((item, i) => (
        <div class={`timeline-item reveal ${i % 2 === 0 ? 'reveal-left' : 'reveal-right'}`}>
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <span class="timeline-period">{item.period}</span>
            <h4 class="timeline-company">{item.company}</h4>
            <span class="timeline-role">{item.role}</span>
            <ul class="timeline-highlights">
              {item.highlights.map((h) => (
                <li>{h}</li>
              ))}
            </ul>
          </div>
        </div>
      ))}
      <div class="timeline-line"></div>
    </div>

    <div class="sales-cta reveal">
      <button class="btn-primary" data-contact>Contact Me</button>
    </div>
  </div>
</section>

<style>
  .sales {
    padding: var(--section-padding);
    position: relative;
  }

  .sales-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .sales-header .section-subtitle {
    margin: 0 auto;
  }

  /* Stats Grid */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-bottom: 60px;
  }

  .stat-card-wrapper {
    perspective: 800px;
  }

  .stat-card {
    position: relative;
    border-radius: var(--border-radius);
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
    transform-style: preserve-3d;
    will-change: transform;
  }

  .stat-card-inner {
    position: relative;
    padding: 40px 24px;
    text-align: center;
    background: rgba(22, 22, 22, 0.6);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(123, 47, 190, 0.15);
    border-radius: var(--border-radius);
    overflow: hidden;
    z-index: 1;
  }

  .stat-card-inner::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--color-purple), var(--color-gold));
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .stat-card:hover .stat-card-inner::before {
    opacity: 1;
  }

  .stat-card:hover {
    box-shadow:
      0 0 30px rgba(123, 47, 190, 0.3),
      0 0 60px rgba(123, 47, 190, 0.15),
      0 20px 40px rgba(0, 0, 0, 0.4);
  }

  .stat-card:hover .stat-card-inner {
    border-color: rgba(123, 47, 190, 0.5);
    background: rgba(22, 22, 22, 0.8);
  }

  .stat-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 120px;
    height: 120px;
    background: radial-gradient(circle, var(--color-purple-glow) 0%, transparent 70%);
    transform: translate(-50%, -50%);
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
    z-index: 0;
  }

  .stat-card:hover .stat-glow {
    opacity: 1;
  }

  .stat-value {
    display: block;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: var(--color-gold);
    margin-bottom: 8px;
    position: relative;
    z-index: 1;
    font-variant-numeric: tabular-nums;
  }

  .stat-label {
    font-size: 0.85rem;
    color: var(--color-gray-200);
    font-weight: 500;
    position: relative;
    z-index: 1;
  }

  /* Strengths */
  .strengths {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    margin-bottom: 80px;
  }

  .strength-pill {
    padding: 10px 20px;
    background: rgba(123, 47, 190, 0.15);
    border: 1px solid rgba(123, 47, 190, 0.3);
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-purple-light);
    transition: all var(--transition-fast);
    white-space: nowrap;
  }

  .strength-pill:hover {
    background: rgba(123, 47, 190, 0.3);
    border-color: var(--color-purple);
    transform: translateY(-2px);
  }

  /* Timeline */
  .timeline {
    position: relative;
    max-width: 800px;
    margin: 0 auto 60px;
    padding: 0 20px;
  }

  .timeline-line {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--color-purple), var(--color-gold), var(--color-purple));
    transform: translateX(-50%);
  }

  .timeline-item {
    position: relative;
    padding: 0 0 48px;
    display: flex;
    width: 50%;
  }

  .timeline-item:nth-child(odd) {
    padding-right: 40px;
    text-align: right;
    align-self: flex-start;
  }

  .timeline-item:nth-child(even) {
    padding-left: 40px;
    margin-left: 50%;
  }

  .timeline-dot {
    position: absolute;
    width: 14px;
    height: 14px;
    background: var(--color-gold);
    border: 3px solid var(--color-bg);
    border-radius: 50%;
    z-index: 2;
    box-shadow: 0 0 20px var(--color-purple-glow);
  }

  .timeline-item:nth-child(odd) .timeline-dot {
    right: -7px;
  }

  .timeline-item:nth-child(even) .timeline-dot {
    left: -7px;
  }

  .timeline-content {
    background: var(--color-bg-card);
    border: 1px solid var(--color-gray-500);
    border-radius: var(--border-radius-sm);
    padding: 24px;
    width: 100%;
    transition: border-color var(--transition-fast);
  }

  .timeline-content:hover {
    border-color: var(--color-purple);
  }

  .timeline-period {
    font-size: 0.8rem;
    color: var(--color-purple-light);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .timeline-company {
    color: var(--color-gold);
    font-size: 1.2rem;
    margin: 8px 0 4px;
  }

  .timeline-role {
    font-size: 0.9rem;
    color: var(--color-gray-200);
    font-style: italic;
    display: block;
    margin-bottom: 12px;
  }

  .timeline-highlights {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .timeline-highlights li {
    font-size: 0.85rem;
    color: var(--color-gray-100);
    line-height: 1.5;
    position: relative;
    padding-left: 16px;
  }

  .timeline-item:nth-child(odd) .timeline-highlights li {
    padding-left: 0;
    padding-right: 16px;
  }

  .timeline-highlights li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--color-purple-light);
    font-size: 0.8rem;
  }

  .timeline-item:nth-child(odd) .timeline-highlights li::before {
    left: auto;
    right: 0;
    content: '←';
  }

  .sales-cta {
    text-align: center;
  }

  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .timeline-line {
      left: 20px;
    }

    .timeline-item,
    .timeline-item:nth-child(odd),
    .timeline-item:nth-child(even) {
      width: 100%;
      padding-left: 50px;
      padding-right: 0;
      margin-left: 0;
      text-align: left;
    }

    .timeline-dot,
    .timeline-item:nth-child(odd) .timeline-dot,
    .timeline-item:nth-child(even) .timeline-dot {
      left: 13px;
      right: auto;
    }

    .timeline-item:nth-child(odd) .timeline-highlights li {
      padding-left: 16px;
      padding-right: 0;
    }

    .timeline-item:nth-child(odd) .timeline-highlights li::before {
      left: 0;
      right: auto;
      content: '→';
    }
  }

  @media (max-width: 480px) {
    .stats-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // ── Count-Up Animation (loops every 10 seconds) ──
  function animateCountUp(el: HTMLElement) {
    const target = parseFloat(el.closest('.stat-card')?.getAttribute('data-numeric') || '0');
    const prefix = el.closest('.stat-card')?.getAttribute('data-prefix') || '';
    const suffix = el.closest('.stat-card')?.getAttribute('data-suffix') || '';
    const decimals = parseInt(el.closest('.stat-card')?.getAttribute('data-decimals') || '0');
    const duration = 2000;
    const startTime = performance.now();

    function update(now: number) {
      const elapsed = now - startTime;
      const progress = Math.min(elapsed / duration, 1);
      // Ease out cubic
      const eased = 1 - Math.pow(1 - progress, 3);
      const current = eased * target;

      el.textContent = prefix + current.toFixed(decimals) + suffix;

      if (progress < 1) {
        requestAnimationFrame(update);
      }
    }

    requestAnimationFrame(update);
  }

  function startCountLoop() {
    const statValues = document.querySelectorAll('.stat-value');
    // Initial run
    statValues.forEach((el) => animateCountUp(el as HTMLElement));
    // Repeat every 10 seconds
    setInterval(() => {
      statValues.forEach((el) => animateCountUp(el as HTMLElement));
    }, 10000);
  }

  // Trigger count-up when stats section enters viewport
  const statsGrid = document.querySelector('.stats-grid');
  let countStarted = false;

  const statsObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting && !countStarted) {
        countStarted = true;
        startCountLoop();
      }
    });
  }, { threshold: 0.3 });

  if (statsGrid) statsObserver.observe(statsGrid);

  // ── 3D Tilt Effect on Stat Cards ──
  const cards = document.querySelectorAll('.stat-card');

  cards.forEach((card) => {
    const el = card as HTMLElement;

    el.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = el.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;

      const rotateX = ((y - centerY) / centerY) * -12;
      const rotateY = ((x - centerX) / centerX) * 12;

      el.style.transform = `rotateX(${rotateX}deg) rotateY(${rotateY}deg) translateZ(10px)`;

      // Move the glow to follow cursor
      const glow = el.querySelector('.stat-glow') as HTMLElement;
      if (glow) {
        glow.style.left = `${x}px`;
        glow.style.top = `${y}px`;
      }
    });

    el.addEventListener('mouseleave', () => {
      el.style.transform = 'rotateX(0deg) rotateY(0deg) translateZ(0px)';
      el.style.transition = 'transform 0.5s cubic-bezier(0.16, 1, 0.3, 1)';
    });

    el.addEventListener('mouseenter', () => {
      el.style.transition = 'transform 0.1s ease, box-shadow 0.4s ease';
    });
  });
</script>
