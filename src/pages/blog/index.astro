---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import ContactModal from '../../components/ContactModal.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const posts = await Promise.all(
  allPosts.map(async (post) => {
    const body = post.body || '';
    const wordCount = body.split(/\s+/).filter(Boolean).length;
    const readingTime = Math.max(1, Math.ceil(wordCount / 230));
    return { ...post, readingTime };
  })
);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}

const tagCounts: Record<string, number> = {};
posts.forEach((post) => {
  post.data.tags?.forEach((tag) => {
    tagCounts[tag] = (tagCounts[tag] || 0) + 1;
  });
});
---

<BaseLayout
  title="Blog — Liam Eyres"
  description="Thoughts on sales leadership, AI in sales, team building, and web development from Liam Eyres."
>
  <Navbar />
  <ContactModal />

  <main class="blog-page">
    <div class="container">
      <div class="blog-header reveal">
        <span class="section-label">Blog</span>
        <h1 class="section-title">Thoughts & Insights</h1>
        <p class="section-subtitle">
          On sales leadership, AI, team building, and everything I'm learning along the way.
        </p>
      </div>

      <!-- Tags Filter -->
      <div class="blog-tags reveal">
        <span class="tag-filter active" data-tag="all">All</span>
        {Object.entries(tagCounts).map(([tag, count]) => (
          <span class="tag-filter" data-tag={tag}>{tag} ({count})</span>
        ))}
      </div>

      <!-- Posts List -->
      <div class="blog-list">
        {posts.map((post, i) => (
          <a
            href={`/blog/${post.id}`}
            class={`blog-card reveal`}
            style={`transition-delay: ${Math.min(i * 0.08, 0.5)}s`}
            data-tags={post.data.tags?.join(',')}
          >
            <div class="blog-card-meta">
              <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
              <span class="blog-reading-time">{post.readingTime} min read</span>
              {post.data.tags?.map((tag) => (
                <span class="blog-tag">{tag}</span>
              ))}
            </div>
            <h2 class="blog-card-title">{post.data.title}</h2>
            <p class="blog-card-excerpt">{post.data.description}</p>
            <span class="blog-card-link">Read Article →</span>
          </a>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .blog-page {
    padding-top: 140px;
    padding-bottom: 80px;
    min-height: 80vh;
  }

  .blog-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .blog-header .section-subtitle {
    margin: 0 auto;
  }

  /* Tags */
  .blog-tags {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 50px;
  }

  .tag-filter {
    padding: 8px 18px;
    background: var(--color-bg-card);
    border: 1px solid var(--color-gray-500);
    border-radius: 50px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-gray-200);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .tag-filter:hover,
  .tag-filter.active {
    background: rgba(123, 47, 190, 0.2);
    border-color: var(--color-purple);
    color: var(--color-purple-light);
  }

  /* Blog List */
  .blog-list {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .blog-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-gray-500);
    border-radius: var(--border-radius);
    padding: 36px;
    transition: all var(--transition-fast);
    display: block;
  }

  .blog-card:hover {
    border-color: var(--color-purple);
    transform: translateX(8px);
    box-shadow: 0 4px 20px rgba(123, 47, 190, 0.1);
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }

  .blog-card-meta time {
    font-size: 0.8rem;
    color: var(--color-gray-300);
  }

  .blog-reading-time {
    font-size: 0.75rem;
    color: var(--color-gray-300);
    opacity: 0.8;
  }

  .blog-tag {
    padding: 3px 10px;
    background: rgba(123, 47, 190, 0.15);
    border-radius: 20px;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-purple-light);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .blog-card-title {
    color: var(--color-white);
    font-size: 1.4rem;
    margin-bottom: 10px;
    line-height: 1.3;
    transition: color var(--transition-fast);
  }

  .blog-card:hover .blog-card-title {
    color: var(--color-gold);
  }

  .blog-card-excerpt {
    font-size: 0.95rem;
    color: var(--color-gray-200);
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .blog-card-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-purple-light);
    transition: color var(--transition-fast);
  }

  .blog-card:hover .blog-card-link {
    color: var(--color-gold);
  }

  .blog-card.hidden {
    display: none;
  }
</style>

<script>
  // Tag filtering
  const filters = document.querySelectorAll('.tag-filter');
  const cards = document.querySelectorAll('.blog-card');

  filters.forEach((filter) => {
    filter.addEventListener('click', () => {
      const tag = (filter as HTMLElement).dataset.tag;

      // Update active state
      filters.forEach((f) => f.classList.remove('active'));
      filter.classList.add('active');

      // Filter cards
      cards.forEach((card) => {
        const cardTags = (card as HTMLElement).dataset.tags || '';
        if (tag === 'all' || cardTags.includes(tag || '')) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });
</script>
